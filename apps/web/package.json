{
  "name": "@velthoryn/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "NEXT_PUBLIC_E2E_MOCK_WALLET=true next dev -H 127.0.0.1 -p 3001",
    "prebuild": "pnpm --filter @velthoryn/client build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:db": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test:e2e": "playwright test",
    "test:e2e:local": "NEXT_PUBLIC_E2E_MOCK_WALLET=true PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001 playwright test",
    "test:e2e:signing": "playwright test --config playwright.signing.config.ts",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:deps": "playwright install-deps chromium"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@sentry/nextjs": "^10.53.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-react-ui": "^0.9.35",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.67.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@velthoryn/client": "workspace:*",
    "@vercel/analytics": "^2.0.1",
    "bs58": "^6.0.0",
    "drizzle-orm": "^0.39.3",
    "keccak256": "^1.0.6",
    "next": "^15.5.18",
    "pino": "^10.3.1",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "~9.39.4",
    "eslint-config-next": "^16.2.6",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
